{
  "expo": {
    "name": "GolpedeSuerte",
    "slug": "GolpedeSuerte",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Logo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/Logo.png",
      "resizeMode": "cover",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/Logo.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "favicon": "./assets/Logo.png"
    },
    "plugins": [
      "expo-font",
      "expo-sqlite",
      "expo-sharing"
    ]
  }
}
